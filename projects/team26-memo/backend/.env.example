# MeetFlow AI 백엔드 환경변수 예시
# 실제 사용 시 .env 로 복사하여 사용 (커밋 금지)

# 사용할 LLM (offline | openai | gemini | anthropic)
# 기본값 offline - API 키 없이도 휴리스틱으로 동작
LLM_PROVIDER=offline

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# 로깅 / CORS
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
