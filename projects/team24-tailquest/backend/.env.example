# Backend environment template — copy to .env and fill in.

# Upstage Solar API key — get one at https://console.upstage.ai
UPSTAGE_API_KEY=

# Solar model to use for analysis/generation/evaluation nodes.
# Default is solar-pro3. Use solar-mini for cheaper / faster but lower-quality runs.
SOLAR_MODEL=solar-pro3

# Set to "true" to bypass Solar API and return canned mock data.
# Useful for frontend development without burning credits.
USE_MOCK_LLM=false

# CORS — comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# (선택) GitHub PAT. 없으면 익명 호출 — IP당 60회/h 제한 → 자료추가 광클 시 403.
# https://github.com/settings/personal-access-tokens 에서 read-only PAT 발급.
GITHUB_TOKEN=
